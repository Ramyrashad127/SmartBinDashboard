using Microsoft.EntityFrameworkCore;
using SmartBin.Api.Data;
using SmartBin.Api.DTOs;
using SmartBin.Api.Models;

namespace SmartBin.Api.Services
{
    public interface IBinService
    {
        Task<IEnumerable<BinDto>> GetBinsAsync(int userId);
        Task<BinDto> CreateBinAsync(int userId);
        Task<bool> UpdateLocationAsync(int binId, UpdateLocationDto dto);
        Task<BinDto> GetBinSectionsAsync(int binId, int userId);
    }

    public class BinService : IBinService
    {
        private readonly AppDbContext _context;

        public BinService(AppDbContext context)
        {
            _context = context;
        }

        public async Task<IEnumerable<BinDto>> GetBinsAsync(int userId)
        {
            return await _context.Bins
                .Where(b => b.UserId == userId)
                .Select(b => new BinDto
                {
                    Id = b.Id,
                    IdentificationToken = b.IdentificationToken,
                    Latitude = b.Latitude,
                    Longitude = b.Longitude,
                    CreatedAt = b.CreatedAt,
                    Sections = b.BinSections.Select(s => new BinSectionDto
                    {
                        MaterialId = s.MaterialId,
                        LevelPercentage = s.LevelPercentage,
                        Weight = s.Weight
                    }).ToList()
                }).ToListAsync();
        }

        public async Task<BinDto> CreateBinAsync(int userId)
        {
            var bin = new Bin
            {
                IdentificationToken = Guid.NewGuid().ToString(),
                Latitude = 0,
                Longitude = 0,
                UserId = userId,
                CreatedAt = DateTime.UtcNow
            };

            _context.Bins.Add(bin);
            await _context.SaveChangesAsync(); // Save to get the generated Bin.Id

            var sections = new List<BinSection>
            {
                new BinSection { BinId = bin.Id, MaterialId = (int)MaterialType.Plastic, LevelPercentage = 0, Weight = 0 },
                new BinSection { BinId = bin.Id, MaterialId = (int)MaterialType.Metal, LevelPercentage = 0, Weight = 0 }
            };

            _context.BinSections.AddRange(sections);
            await _context.SaveChangesAsync();

            return new BinDto
            {
                Id = bin.Id,
                IdentificationToken = bin.IdentificationToken,
                CreatedAt = bin.CreatedAt,
                Sections = sections.Select(s => new BinSectionDto
                {
                    MaterialId = s.MaterialId,
                    LevelPercentage = s.LevelPercentage,
                    Weight = s.Weight
                }).ToList()
            };
        }

        public async Task<bool> UpdateLocationAsync(int binId, UpdateLocationDto dto)
        {
            var bin = await _context.Bins.FirstOrDefaultAsync(b => b.Id == binId && b.IdentificationToken == dto.Token);
            if (bin == null) return false;

            bin.Latitude = dto.Latitude;
            bin.Longitude = dto.Longitude;
            await _context.SaveChangesAsync();
            return true;
        }

        public async Task<BinDto> GetBinSectionsAsync(int binId, int userId)
        {
            return await _context.Bins
            .Where(b => b.Id == binId && b.UserId == userId)
            .Select(b => new BinDto
            {
                Id = b.Id,
                Sections = b.BinSections.Select(s => new BinSectionDto
                {
                    MaterialId = s.MaterialId,
                    LevelPercentage = s.LevelPercentage,
                    Weight = s.Weight
                }).ToList()
            }).FirstOrDefaultAsync();
        }
    }
}
